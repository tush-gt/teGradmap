  "_meta": {
    "project": "GradMap",
    "version": "1.1.0",
    "description": "Maps raw branch name variants extracted from CET PDFs to canonical branch names. All keys are lowercased and stripped for matching. Add new variants here — never patch normalization logic into scripts.",
    "key_format": "lowercase, stripped, no leading/trailing whitespace",
    "value_format": "Title Case canonical name",
    "last_updated": "2026-05-09",
    "instructions": {
      "adding_variants": "When a new raw branch name appears post-extraction, add it under the correct canonical name. Do NOT create a new canonical unless it is genuinely a new discipline.",
      "unmapped_handling": "If a branch cannot be confidently mapped, leave it as UNKNOWN_BRANCH and log it. Do NOT guess.",
      "wrapped_artifacts": "Extraction sometimes wraps two columns into one cell e.g. 'Electronics and\\nTelecommunication Engg'. These are included as variants with \\n replaced by space."
    }
