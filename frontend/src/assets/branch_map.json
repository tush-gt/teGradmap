{
  "_meta": {
    "project": "GradMap",
    "version": "1.0.0",
    "description": "Maps raw branch name variants found in CET PDFs to a single canonical branch name. Used exclusively in the normalize stage. NEVER hardcode normalization logic in extraction scripts. Always add new variants here instead of patching scripts.",
    "instructions": {
      "adding_variants": "When extraction produces an unrecognized branch name, add it under the correct canonical entry's 'variants' list. Do not create a new canonical entry unless it is genuinely a different branch.",
      "canonical_format": "Title Case. Full name. No abbreviations. Example: 'Computer Engineering' not 'Comp Engg'.",
      "unknown_handling": "If a raw branch name cannot be confidently mapped, do NOT guess. Flag it in the validate stage and add to the 'unmapped_variants_log' in your validation report."
    }
  },

